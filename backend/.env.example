# Backend Environment Configuration
# Copy this file to .env and fill in actual values

# Flask Configuration
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Upload Session Configuration (in minutes)
UPLOAD_TTL_MINUTES=90
MAX_UPLOAD_SESSIONS=25

# Request Timeout Configuration (in seconds)
REQUEST_TIMEOUT=30

# Groq AI Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT=30

# Optional: Custom logging level
# LOG_LEVEL=INFO
